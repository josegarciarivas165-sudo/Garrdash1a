{
  "appId": "com.garricraft.garrdash",
  "appName": "GarrDash",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0F172A",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  },
  "ios": {
    "contentInset": "automatic"
  },
  "android": {
    "backgroundColor": "#0F172A"
  }
}
